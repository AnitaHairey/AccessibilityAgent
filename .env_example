# Environment Variables for AI Weather Agent

# Azure OpenAI Configuration
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_ENDPOINT=your-azure-openai-endpoint-here
AZURE_OPENAI_DEPLOYMENT_NAME=your-azure-openai-deployment-name-here

# Optional: Specify API version (default: 2024-02-15-preview)
AZURE_OPENAI_API_VERSION=your-azure-openai-api-version-here

# Optional: Specify temperature for AI responses (0.0 - 1.0, default: 0.1)
# OPENAI_TEMPERATURE=0.1
